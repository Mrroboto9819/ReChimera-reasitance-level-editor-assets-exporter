target/
**/*.rs.bk
Cargo.lock.bak
app/desktop/.tauri

# Tauri (added in step 2)
node_modules/
app/node_modules/
dist/
src-tauri/target/

# IDE
.vscode/
.idea/

# Temp / scratch dumps
tmp_textures/
tmp/
tmp_*/
*.tsbuildinfo

# Insomniac game data — copyrighted, never commit
*.dat
levels/
highmips/
shaders/
mobys/
ties/
zones/
gameplay/

# Tauri auto-generated (regenerated by tauri-build)
apps/desktop/src-tauri/gen/

# Signing / release keys + secrets. The folder rules below catch the
# conventional spots people drop signing material; the file
# extensions catch keys that end up elsewhere by accident. Better
# to over-ignore than to leak a private key.
*.pem
*.key
*.pfx
*.p12                  # PKCS#12 keystore (alt format for .pfx)
*.pkcs12
*.jks                  # Java keystore
*.crt                  # Usually public certs, still cert material
*.cer
*_rsa                  # OpenSSH private keys (id_rsa, deploy_rsa, …)
*.kdbx                 # KeePass database
.tauri/                # Tauri auto-updater signing key folder
keys/                  # Generic folder name for signing material
secrets/
.secrets/
service-account*.json  # GCP / Firebase / Google Cloud service creds

# Compiled vite config emitted by `tsc -b`
apps/desktop/vite.config.js
apps/desktop/vite.config.d.ts

# Environment / secrets
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini
