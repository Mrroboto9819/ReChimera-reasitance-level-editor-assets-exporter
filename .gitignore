target/
**/*.rs.bk
Cargo.lock.bak
app/desktop/.tauri

# Tauri (added in step 2)
node_modules/
app/node_modules/
dist/
src-tauri/target/

# IDE
.vscode/
.idea/

# Temp / scratch dumps
tmp_textures/
tmp/
tmp_*/
*.tsbuildinfo

# Insomniac game data — copyrighted, never commit
*.dat
levels/
highmips/
shaders/
mobys/
ties/
zones/
gameplay/

# Tauri auto-generated (regenerated by tauri-build)
apps/desktop/src-tauri/gen/

# Signing / release keys + secrets. The folder rules below catch
# conventional spots people drop signing material; the file
# extensions catch keys that end up elsewhere by accident. Better
# to over-ignore than to leak a private key.
#
# IMPORTANT: gitignore does NOT support inline comments — every
# pattern below must be on its own line, no trailing `# ...` text,
# or the whole line gets parsed as a literal pattern that matches
# nothing.

# Cert / key material (covers .key, .key.pub, .pem, etc.)
*.pem
*.key
*.key.pub
*.pfx
*.p12
*.pkcs12
*.jks
*.crt
*.cer
*_rsa
*.kdbx

# Tauri auto-updater signing key folder
.tauri/

# Generic stash folders for signing material / credentials
keys/
secrets/
.secrets/

# GCP / Firebase / Google Cloud service-account credentials
service-account*.json

# Compiled vite config emitted by `tsc -b`
apps/desktop/vite.config.js
apps/desktop/vite.config.d.ts

# Environment / secrets
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini
